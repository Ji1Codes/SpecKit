# Base URL of your Jira instance (e.g. https://yourcompany.atlassian.net)
JIRA_BASE_URL=https://yourcompany.atlassian.net

# Email address associated with your Jira account
JIRA_EMAIL=you@yourcompany.com

# Jira API token — generate at https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=your_jira_api_token

# Jira project key to poll (e.g. PROJ)
JIRA_PROJECT_KEY=PROJ

# Azure OpenAI — required for the SpecKit AI pipeline
AZURE_OPENAI_LLM_MODEL_API_BASE=https://your-resource.openai.azure.com/
AZURE_OPENAI_LLM_MODEL_API_KEY=your_azure_openai_api_key
AZURE_OPENAI_LLM_MODEL_API_VERSION=2024-02-01
AZURE_OPENAI_LLM_MODEL_LLM_MODEL=gpt-4o
